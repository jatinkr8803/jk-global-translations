# JK Global Translations — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001

# SMTP Email (Gmail example — use App Password, not regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# Notification email (where leads are sent)
NOTIFY_EMAIL=jatin@jkglobaltranslations.com

# Frontend URL (for CORS — use * for any)
FRONTEND_URL=https://your-netlify-site.netlify.app

# Admin API key (for /leads endpoint)
ADMIN_KEY=change_this_to_a_secure_random_string
